  "races": {
    "northerner": {
      "name": "Северянин",
      "description": "Суровые жители северных земель. В постоянной борьбе с холодом и дикой природой они приобрели небывалую силу. Северяне крепки телом и духом, предпочитают решать вопросы силой, а не хитростью. Бонус: Сила +1, урон +1",
      "startZone": "village",
      "startRoom": "village_square",
      "bonuses": { "strength": 1, "damroll": 1 }
    },
    "eastern": {
      "name": "Житель востока",
      "description": "Ловкие и быстрые, прирожденные охотники и воины. Их тела закалены в бесчисленных межродовых стычках, а движения отточены до совершенства. Восточные жители чувствуют себя как дома и в густых лесах, и в бескрайних степях. Бонус: Ловкость +1, восст. выносливости +3",
      "startZone": "village",
      "startRoom": "village_square",
      "bonuses": { "dexterity": 1 },
      "regenBonus": { "staminaRegen": 3 }
    },
    "southerner": {
      "name": "Южанин",
      "description": "Мудрые торговцы и мореплаватели, потомки древних цивилизаций. Среди них часто встречаются искусные маги и дипломаты. Южане умеют находить общий язык с кем угодно, а их знания тайн мироздания передаются из поколения в поколение. Бонус: Мудрость +1, восст. маны +3",
      "startZone": "southwest_village",
      "startRoom": "r3c4",
      "bonuses": { "wisdom": 1 },
      "regenBonus": { "manaRegen": 3 }
    },
    "barbarian": {
      "name": "Варвар",
      "description": "Дикие племена, живущие за пределами цивилизации. Обладают крепким телом и отличным здоровьем, привыкли сражаться буквально голыми руками. Варвары могут вынести такие повреждения, от которых любой другой падет замертво. Бонус: Телосложение +1, восст. здоровья +3",
      "startZone": "village",
      "startRoom": "village_square",
      "bonuses": { "constitution": 1 },
      "regenBonus": { "healthRegen": 3 }
    },
    "western": {
      "name": "Житель запада",
      "description": "Народ, веками развивавший свой интеллект и постигавший тайны магии. Западные земли славятся своими библиотеками, университетами и величайшими волшебниками. Жители запада — прирожденные маги, для которых колдовство так же естественно, как дыхание. Бонус: Интеллект +1, сила заклинаний +10%",
      "startZone": "southwest_village",
      "startRoom": "r3c4",
      "bonuses": { "intelligence": 1 },
